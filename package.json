{
  "name": "theusufruct-site",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "theusufruct.com — the Louisiana Civil Code as a readable, linkable, searchable web artifact.",
  "scripts": {
    "prebuild": "bash scripts/fetch-corpus.sh",
    "predev": "bash scripts/fetch-corpus.sh",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist --output-subdir _pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "fetch": "bash scripts/fetch-corpus.sh"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/source-serif-4": "^5.1.0",
    "astro": "^5.5.0"
  },
  "devDependencies": {
    "pagefind": "^1.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
