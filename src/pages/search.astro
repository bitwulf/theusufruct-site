---
import Base from '../layouts/Base.astro';
const isDev = import.meta.env.DEV;
---
<Base
  title="Search"
  description="Full-text search of the Louisiana Civil Code. Filter by status and Book."
  searchable={false}
>
  <article>
    <h1>Search</h1>
    <p style="color: var(--ink-mute); font-family: var(--mono); font-size: 0.88rem; margin-bottom: var(--space-5);">
      Press <kbd>⌘K</kbd> from any page to land here. Search runs entirely in your browser.
    </p>

    <div id="search" data-pagefind-no-result-hide data-dev={isDev ? '1' : '0'}></div>

    <noscript>
      <p class="callout">
        Search requires JavaScript (the index runs in your browser).
        You can still <a href="/cc">browse the Code</a> structurally without it.
      </p>
    </noscript>
  </article>

  <link rel="stylesheet" href="/_pagefind/pagefind-ui.css" />
  <script src="/_pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      var mount = document.getElementById('search');
      var isDev = mount && mount.getAttribute('data-dev') === '1';

      if (typeof PagefindUI === 'undefined') {
        if (isDev) {
          mount.innerHTML =
            '<p class="callout">' +
            'Search index isn’t served by <code>astro dev</code> on its own — it’s only built by ' +
            '<code>npm run build</code>. Run that once and the index is mirrored to ' +
            '<code>public/_pagefind/</code>, so dev reloads will serve it from then on.' +
            '</p>';
        } else {
          mount.innerHTML =
            '<p class="callout">' +
            'Search index unavailable. Try <a href="/cc">browsing the Code</a> instead.' +
            '</p>';
        }
        return;
      }
      new PagefindUI({
        element: '#search',
        showImages: false,
        showSubResults: true,
        resetStyles: false,
        bundlePath: '/_pagefind/',
        excerptLength: 30,
        showEmptyFilters: false,
        translations: {
          placeholder: 'Search the Civil Code…',
          zero_results: 'No matches for "[SEARCH_TERM]".'
        }
      });
      setTimeout(function () {
        var input = document.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      }, 50);
    });
  </script>

  <style is:global>
    #search { margin-top: var(--space-4); }
    .pagefind-ui__search-input {
      font-family: var(--serif) !important;
      font-size: 1.1rem !important;
      padding: 0.6em 0.9em !important;
      background: var(--bg) !important;
      color: var(--ink) !important;
      border: 1px solid var(--rule) !important;
    }
    .pagefind-ui__search-input:focus {
      border-color: var(--accent) !important;
      outline: 2px solid var(--accent) !important;
      outline-offset: 1px !important;
    }
    .pagefind-ui__result-title a { color: var(--accent) !important; font-family: var(--serif) !important; }
    .pagefind-ui__result-excerpt { color: var(--ink-soft) !important; font-family: var(--serif) !important; }
    .pagefind-ui__result-tags, .pagefind-ui__filter-name { font-family: var(--mono) !important; font-size: 0.78rem !important; }
    .pagefind-ui__filter-block { color: var(--ink-soft); }
    .pagefind-ui__filter-name { color: var(--ink-mute) !important; font-family: var(--mono) !important; }
    .pagefind-ui__filter-label { color: var(--ink) !important; font-family: var(--serif) !important; }
    .pagefind-ui mark { background: color-mix(in srgb, var(--accent) 22%, transparent); color: inherit; padding: 0 0.1em; }
  </style>
</Base>
