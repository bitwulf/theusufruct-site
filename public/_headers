# Cloudflare Pages: long-cache the immutable, hashed Astro assets and fonts.
# HTML stays at the default short cache so deploys propagate quickly.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/_pagefind/*
  Cache-Control: public, max-age=604800

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Per-article downloads — content-addressed by snapshot tag, safe to cache long.
/cc/*.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

/cc/*.md
  Cache-Control: public, max-age=86400
  Content-Type: text/markdown; charset=utf-8
