---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { rootContainers, countArticlesIn, manifest, release, stepLabel } from '../../lib/corpus.ts';

const totalArticles = manifest.totals.articles_emitted;
const activeArticles = manifest.totals.by_status.active ?? 0;
---
<Base
  title="Louisiana Civil Code"
  description="The Louisiana Civil Code as a readable, citable web artifact. Preliminary Title and Books I–IV, with stable per-article URLs."
>
  <section>
    <Breadcrumb crumbs={[{ label: 'Civil Code', href: '/cc' }]} />
    <header class="container-page__head">
      <div class="container-page__kicker">Civil Code</div>
      <h1 class="container-page__title">Louisiana Civil Code</h1>
      <p class="container-page__meta">
        {totalArticles.toLocaleString()} article records · {activeArticles.toLocaleString()} active
        · snapshot <a href={release.releasePage} rel="noopener">{release.tag}</a>
      </p>
    </header>

    <p class="prose" style="margin-bottom: var(--space-6); max-width: 60ch;">
      Browse by structure below, jump directly to an article (every article has a stable
      short URL, e.g. <a href="/cc/2315"><code>/cc/2315</code></a>), or
      <a href="/search">search the full text</a>.
    </p>

    <ul class="child-list">
      {rootContainers.map((c) => {
        const cn = countArticlesIn(c);
        return (
          <li class="child-list__item">
            <a href={c.url}>
              <div class="child-list__lvl">{stepLabel(c.self)}</div>
              <div class="child-list__name">{c.name}</div>
              <div class="child-list__meta">
                Arts. {c.range_start}–{c.range_end} · {cn.active} active
                {cn.repealed > 0 && ` · ${cn.repealed} repealed`}
                {cn.blank > 0 && ` · ${cn.blank} blank`}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</Base>
