---
import '../styles/global.css';
import '../styles/print.css';
import { release } from '../lib/corpus.ts';

export interface Props {
  title: string;
  description?: string;
  /** Canonical path (with leading slash, no origin). */
  canonical?: string;
  /** Article number — when set, OG type becomes article and the title gets a citable form. */
  articleNumber?: string;
  /** Add a noindex meta. */
  noindex?: boolean;
  /** Set to false on listing/landing pages where Pagefind shouldn't index. */
  searchable?: boolean;
  /** Narrow body width (for the article template). */
  narrow?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'The Louisiana Civil Code, readable and citable. A publication of the public-domain Civil Code corpus.',
  canonical,
  noindex = false,
  searchable = true,
  narrow = false,
  bodyClass = '',
} = Astro.props;

const fullTitle = title === 'Usufruct'
  ? 'Usufruct — Louisiana Civil Code'
  : `${title} · Usufruct`;

const origin = 'https://theusufruct.com';
function normalizePath(p: string): string {
  // Canonical URLs do not carry trailing slashes (except root).
  if (p === '/' || p === '') return '/';
  return p.replace(/\/+$/, '');
}
const canonicalUrl = canonical
  ? new URL(normalizePath(canonical), origin).toString()
  : new URL(normalizePath(Astro.url.pathname), origin).toString();

const pageNav: Array<{ href: string; label: string }> = [
  { href: '/cc', label: 'Code' },
  { href: '/search', label: 'Search' },
  { href: '/data', label: 'Data' },
  { href: '/about', label: 'About' },
];

const isCurrent = (href: string) => {
  const p = Astro.url.pathname.replace(/\/$/, '');
  const target = href.replace(/\/$/, '');
  if (target === '') return p === '';
  return p === target || p.startsWith(target + '/');
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex" />}
    {!searchable && <meta name="pagefind-ignore" content="all" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Usufruct" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />

    <link rel="alternate" type="application/atom+xml" title="Usufruct — releases" href="/feed.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta name="generator" content="Astro" />
    <meta name="usufruct-tag" content={release.tag} />
    <meta name="usufruct-generated" content={release.generatedAt} />

    <script is:inline>
      // Apply persisted theme synchronously to avoid flash.
      try {
        var stored = localStorage.getItem('usufruct-theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      } catch (_) { /* ignore */ }
    </script>
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__brand" aria-label="Usufruct home">
          <span class="mark">Usufruct</span>
        </a>
        <nav class="site-header__nav" aria-label="Primary">
          {pageNav.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
          <button
            type="button"
            class="search-trigger"
            data-search-trigger
            aria-label="Open search (⌘K)"
            title="Search (⌘K)"
          >
            <span aria-hidden="true">⌕</span>
            <span class="hide-mobile">Search</span>
            <kbd>⌘K</kbd>
          </button>
          <button
            type="button"
            class="theme-toggle"
            data-theme-toggle
            aria-label="Toggle dark mode"
            title="Toggle theme"
          >
            <span data-theme-icon>◐</span>
          </button>
        </nav>
      </div>
    </header>

    <main id="main" class={narrow ? 'narrow' : ''}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__col">
          <h2>Usufruct</h2>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/roadmap">Roadmap</a></li>
            <li><a href="/colophon">Colophon</a></li>
            <li><a href="/feed.xml">Atom feed</a></li>
          </ul>
        </div>
        <div class="site-footer__col">
          <h2>Source</h2>
          <ul>
            <li><a href={release.releasePage} rel="noopener">Snapshot {release.tag}</a></li>
            <li><a href="https://github.com/bitwulf/Usufruct" rel="noopener">Corpus repo</a></li>
            <li><a href="/data">Download</a></li>
            <li>
              <span style="color:var(--ink-mute)">Code: public domain.</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="site-footer__imprint">
        Produced by
        <a href="https://logicalappeals.com" rel="noopener">Logical Appeals, LLC</a>.
      </div>
    </footer>

    <script is:inline>
      // Theme toggle.
      (function () {
        var btn = document.querySelector('[data-theme-toggle]');
        if (!btn) return;
        function current() {
          var t = document.documentElement.getAttribute('data-theme');
          if (t === 'light' || t === 'dark') return t;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        function paintIcon() {
          var icon = btn.querySelector('[data-theme-icon]');
          if (icon) icon.textContent = current() === 'dark' ? '☾' : '☀';
        }
        paintIcon();
        btn.addEventListener('click', function () {
          var next = current() === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('usufruct-theme', next); } catch (_) {}
          paintIcon();
        });
      })();

      // ⌘K opens /search (with focus on the field). If we're already on /search,
      // focus the input. The popover-style search isn't built; navigation is fine
      // and keeps the bundle zero-JS on every page that isn't /search.
      (function () {
        var trigger = document.querySelector('[data-search-trigger]');
        function go() {
          if (location.pathname.replace(/\/$/, '') === '/search') {
            var input = document.querySelector('.pagefind-ui__search-input');
            if (input) { input.focus(); return; }
          }
          location.href = '/search';
        }
        if (trigger) trigger.addEventListener('click', go);
        window.addEventListener('keydown', function (e) {
          var isK = (e.key === 'k' || e.key === 'K');
          if (isK && (e.metaKey || e.ctrlKey)) {
            e.preventDefault();
            go();
          }
        });
      })();
    </script>
  </body>
</html>
<style is:global>
  .hide-mobile { display: inline; }
  @media (max-width: 480px) {
    .hide-mobile { display: none; }
  }
</style>
